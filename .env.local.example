# Supabase — NOTE: key is PUBLISHABLE_KEY not ANON_KEY (recently renamed)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=

# kie.ai (codex/LLM endpoint only — media routes through piapi now)
KIEAI_CODEX_KEY=

# piapi.ai (primary media provider — video, enhance, staging, sky)
PIAPI_API_KEY=

# Trigger.dev v4
TRIGGER_SECRET_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Video engine (deterministic multi-image pipeline)
# Anthropic tool-use orchestrator
ANTHROPIC_API_KEY=
# Path to a Google Cloud service-account JSON with Vision API enabled
GOOGLE_APPLICATION_CREDENTIALS=
# Optional override for orchestrator model (defaults to claude-opus-4-6)
# ENGINE_ORCHESTRATOR_MODEL=claude-opus-4-6
# Optional override for bundled music dir (defaults to src/lib/engine/assets/music)
# ENGINE_MUSIC_DIR=
